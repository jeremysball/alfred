#!/bin/bash
# Pre-commit hook for code quality checks
# Run once to activate: git config core.hooksPath .githooks

set -e

echo "Running ruff check..."
uv run ruff check src/

echo "Running mypy --strict..."
uv run mypy --strict src/

echo "Running completions sync check..."
uv run python scripts/generate-static-completions.py --check

echo "Pre-commit checks complete. Run 'uv run pytest' manually for full test suite."
