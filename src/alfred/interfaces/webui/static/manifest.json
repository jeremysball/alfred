{
  "name": "Alfred - AI Coding Assistant",
  "short_name": "Alfred",
  "description": "Your AI-powered coding companion for complex development tasks",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#3b82f6",
  "orientation": "any",
  "scope": "/",
  "lang": "en",
  "dir": "ltr",
  "categories": ["productivity", "developer", "utilities"],
  "icons": [
    {
      "src": "/static/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/static/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png"
    },
    {
      "src": "/static/icons/icon-maskable-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/static/icons/icon-maskable-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/static/icons/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml"
    }
  ],
  "screenshots": [
    {
      "src": "/static/screenshots/desktop.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide"
    },
    {
      "src": "/static/screenshots/mobile.png",
      "sizes": "750x1334",
      "type": "image/png",
      "form_factor": "narrow"
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "media",
          "accept": ["image/*", "text/*", "application/*"]
        }
      ]
    }
  },
  "shortcuts": [
    {
      "name": "New Session",
      "short_name": "New",
      "description": "Start a new conversation",
      "url": "/new",
      "icons": [{ "src": "/static/icons/shortcut-new.png", "sizes": "96x96" }]
    },
    {
      "name": "Resume Session",
      "short_name": "Resume",
      "description": "Continue previous conversation",
      "url": "/resume",
      "icons": [{ "src": "/static/icons/shortcut-resume.png", "sizes": "96x96" }]
    }
  ]
}
